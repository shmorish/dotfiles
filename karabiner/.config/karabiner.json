                    "shell_command": "osascript -e 'tell application \"System Events\" to set is_running to (name of processes) contains \"iTerm2\"' -e 'if is_running then' -e 'tell application \"iTerm\" to activate' -e 'else' -e 'tell application \"iTerm\"' -e 'create window with profile \"SemiTransparent\"' -e 'activate' -e 'end tell' -e 'end if'"
